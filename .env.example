# PostgreSQL
POSTGRES_USER=apiforge
POSTGRES_PASSWORD=apiforge_secret
POSTGRES_DB=apiforge
DATABASE_URL=postgresql://apiforge:apiforge_secret@localhost:5432/apiforge

# Redis
REDIS_URL=redis://localhost:6379

# MinIO (S3-compatible)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin_secret
MINIO_ENDPOINT=http://localhost:9000

# NATS
NATS_URL=nats://localhost:4222

# Auth — REQUIRED: generate with: openssl rand -hex 32
JWT_SECRET=change_me_in_production_must_be_32_chars_min
JWT_REFRESH_SECRET=change_me_refresh_secret_must_be_32_chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=30d

# Cerbos (policy engine)
CERBOS_URL=http://localhost:3593

# App
NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:3000

# OAuth (optional for local dev)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# CI secrets — set these in GitHub repo settings → Secrets and variables → Actions:
# CI_POSTGRES_PASSWORD  (any strong password for the test DB)
# CI_JWT_SECRET         (openssl rand -hex 32)
# CI_JWT_REFRESH_SECRET (openssl rand -hex 32)
