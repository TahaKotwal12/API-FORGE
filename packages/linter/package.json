{
  "name": "@apiforge/linter",
  "version": "0.1.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "dev": "tsc -p tsconfig.build.json --watch",
