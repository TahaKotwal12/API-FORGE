[package]
name = "{{ name }}"
version = "{{ version }}"
edition = "2021"
rust-version = "1.75"

[dependencies]
reqwest = { version = "0.12", features = ["json", "rustls-tls"], default-features = false }
serde = { version = "1", features = ["derive"] }
serde_json = "1"
chrono = { version = "0.4", features = ["serde"] }
uuid = { version = "1", features = ["serde", "v4"] }
thiserror = "1"
tokio = { version = "1", features = ["rt"] }
